{
  "name": "@llmtr/monorepo",
  "type": "module",
  "version": "0.0.3",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "esno scripts/prepare.ts",
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "lint": "eslint . --cache --concurrency=auto",
    "lint:fix": "eslint . --cache --concurrency=auto --fix",
    "lint:inspect": "npx @eslint/config-inspector",
    "release": "bumpp -r && pnpm publish -r",
    "publish:test": "pnpm publish -r --dry-run",
    "test": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@types/node": "catalog:dev",
    "bumpp": "catalog:dev",
    "eslint": "catalog:dev",
    "esno": "catalog:dev",
    "execa": "catalog:dev",
    "lint-staged": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,md}": [
      "eslint --cache --fix"
    ]
  }
}
