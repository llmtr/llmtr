{
  "name": "@llmtr/cli",
  "type": "module",
  "version": "0.0.2",
  "description": "AI-powered translation CLI — translate text & files using your favourite LLM",
  "author": "Moozon <muzhenweizh@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/llmtr/llmtr",
  "repository": {
    "type": "git",
    "url": "https://github.com/llmtr/llmtr.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/llmtr/llmtr/issues"
  },
  "keywords": [
    "ai",
    "translation",
    "llm",
    "cli",
    "tui",
    "i18n",
    "openai",
    "anthropic",
    "deepseek",
    "terminal"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "bin": {
    "llmtr": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "link": "npm link",
    "unlink": "npm unlink -g @llmtr/cli"
  },
  "dependencies": {
    "@llmtr/core": "workspace:*",
    "citty": "catalog:prod",
    "ink": "catalog:prod",
    "ink-spinner": "catalog:prod",
    "ink-text-input": "catalog:prod",
    "pathe": "catalog:prod",
    "react": "catalog:prod",
    "terminal-link": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
