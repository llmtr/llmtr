{
  "name": "@llmtr/core",
  "type": "module",
  "version": "0.0.2",
  "description": "Core AI translation API for llmtr — reusable across tools",
  "author": "Moozon <muzhenweizh@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/llmtr/llmtr/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/llmtr/llmtr.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/llmtr/llmtr/issues"
  },
  "keywords": [
    "ai",
    "translation",
    "llm",
    "openai",
    "anthropic",
    "i18n",
    "cli"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:prod",
    "@ai-sdk/deepseek": "catalog:prod",
    "@ai-sdk/google": "catalog:prod",
    "@ai-sdk/mistral": "catalog:prod",
    "@ai-sdk/openai": "catalog:prod",
    "ai": "catalog:prod",
    "pathe": "catalog:prod",
    "undici": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
